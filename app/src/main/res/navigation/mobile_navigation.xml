<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mobile_navigation"
    app:startDestination="@+id/nav_home">

    <fragment
        android:id="@+id/nav_home"
        android:name="com.example.evaluacinprctica2.ui.home.HomeFragment"
        android:label="@string/menu_home"
        tools:layout="@layout/fragment_home">
        <action
            android:id="@+id/action_home_to_editCar"
            app:destination="@id/fragment_edit_car" />
    </fragment>

    <fragment
        android:id="@+id/nav_gallery"
        android:name="com.example.evaluacinprctica2.ui.cuenta.GalleryFragment"
        android:label="@string/menu_gallery"
        tools:layout="@layout/fragment_cuenta" />

    <fragment
        android:id="@+id/nav_slideshow"
        android:name="com.example.evaluacinprctica2.ui.creditos.SlideshowFragment"
        android:label="@string/menu_slideshow"
        tools:layout="@layout/fragment_creditos" />



<fragment
    android:id="@+id/fragment_edit_car"
    android:name="com.example.evaluacinprctica2.ui.home.EditCarFragment"
    android:label="EditCar"
    tools:layout="@layout/fragment_edit_car" />


    <fragment
        android:id="@+id/nav_add_car"
        android:name="com.example.evaluacinprctica2.ui.home.AddCarFragment"
        android:label="Agregar Vehículo"
        tools:layout="@layout/fragment_add_car">
        <action
            android:id="@+id/action_addCarFragment_to_homeFragment"
            app:destination="@id/nav_home" />
    </fragment>
</navigation>